{
  "_version": "1.83.0",
  "sap.app": {
    "id": "com.excnorthwindproject.excnorthwindproject",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "ed5ad21e-8b99-4b61-9dc2-9e8ca268696b"
    },
    "dataSources": {
      "mainService": {
        "uri": "/v2/northwind/northwind.svc/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.excnorthwindproject.excnorthwindproject.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      },
      "layout":{
        "type": "sap.ui.model.json.JSONModel",
        "preload": true
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
  "config": {
    "routerClass": "sap.f.routing.Router",
    "viewType": "XML",
    "viewPath": "com.excnorthwindproject.excnorthwindproject.view",
    "controlId": "fcl",
    "clearControlAggregation": true,
    "async": true
  },
  "routes": [
    {
      "name": "Home",
      "pattern": "",
      "target": ["Master"]
    },
    {
      "name": "SupplierDetail",
      "pattern": "SupplierDetail/{SupplierID}",
      "target": ["Master", "Detail"]
    }
  ],
  "targets": {
    "Master": {
      "viewName": "View1",
      "viewType": "XML",
      "controlAggregation": "beginColumnPages",
      "viewId": "idView1",
      "clearControlAggregation": false
    },
    "Detail": {
      "viewName": "View2",
      "viewId": "idView2",
      "viewType": "XML",
      "controlAggregation": "midColumnPages",
      "clearControlAggregation": false
    }
  }
},
    "rootView": {
      "viewName": "com.excnorthwindproject.excnorthwindproject.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}