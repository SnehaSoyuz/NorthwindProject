<mvc:View xmlns:f="sap.f" controllerName="com.excnorthwindproject.excnorthwindproject.controller.View1"
    xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}" class="myCustomPage">
    <headerContent>
      <Select change="onChangeLanguage">
        <items>
          <core:Item key="en" text="{i18n>EN_SELECT}"></core:Item>
          <core:Item key="es" text="{i18n>ES_SELECT}"></core:Item>
        </items>
      </Select>
    </headerContent>
    <content>
    <VBox>
     <Toolbar>
       <Title text="{i18n>FILTER_TITLE}"></Title>
       <ToolbarSpacer />
       <SearchField id="idSearch" width="50%" placeholder="Search Products" liveChange="onSearch"></SearchField>
     </Toolbar>
    <Table id="idTable" items="{/Products}" class="sapUiTinyMargin myCustomTable" 
           alternateRowColors="true" sticky="ColumnHeaders">
      <columns>
        <Column><Text text="{i18n>PRODUCTID_TXT}"></Text></Column>
        <Column><Text text="{i18n>PROD_NAME_TXT}"></Text></Column>
        <Column><Text text="{i18n>SUPP_ID_TXT}"></Text></Column>
        <Column><Text text="{i18n>CATE_ID_TXT}"></Text></Column>
        <Column><Text text="{i18n>QUANT_UNIT_TXT}"></Text></Column>
        <Column><Text text="{i18>PRICE_TXT}"></Text></Column>
        <Column><Text text="{i18n>UNIT_STOCK_TXT}"></Text></Column>
        <Column><Text text="{i18n>UNIT_ORDER_TXT}"></Text></Column>
        <Column><Text text="{i18n>RECORD_TXT}"></Text></Column>
        <Column><Text text="{i18n>DISCONT_TXT}"></Text></Column>

      </columns>
      <items>
       <ColumnListItem>
        <cells><Text text="{ProductID}"></Text></cells>
        <cells><Text text="{ProductName}"></Text></cells>
        <cells><Text text="{SupplierID}"></Text></cells>
        <cells><Text text="{CategoryID}"></Text></cells>
        <cells><Text text="{QuantityPerUnit}"></Text></cells>
        <cells><Text text="{UnitPrice}"></Text></cells>
        <cells><Text text="{UnitsInStock}"></Text></cells>
        <cells><Text text="{UnitsOnOrder}"></Text></cells>
        <cells><Text text="{ReorderLevel}"></Text></cells>
        <cells><Text text="{Discontinued}"></Text></cells>
       </ColumnListItem>
      </items>
    </Table>
    </VBox>
    </content>
    </Page>
</mvc:View>