<mvc:View
    xmlns:f="sap.f"
    controllerName="com.excnorthwindproject.excnorthwindproject.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns="sap.m"
>
    <f:DynamicPage
        id="idDynamicPage"
        class="myCustomPage"
        showFooter="true"
        preserveHeaderStateOnScroll="true"
    >
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>title}" />
                </f:heading>
                <f:actions>
                    <Select change="onChangeLanguage">
                        <items>
                            <core:Item
                                key="en"
                                text="{i18n>EN_SELECT}"
                            />
                            <core:Item
                                key="es"
                                text="{i18n>ES_SELECT}"
                            />
                        </items>
                    </Select>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader>
                <fb:FilterBar
                    id="myFilterBar"
                    useToolbar="false"
                    search="onFilter"
                >
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem
                            name="ProductName"
                            label="Product Name"
                            groupName="Group1"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <MultiComboBox
                                    name="ProductName"
                                    selectionChange=".onSelectionChange"
                                    items="{
												path: '/Products',
												templateShareable: true
											}"
                                >
                                    <core:Item
                                        key="{ProductName}"
                                        text="{ProductName}"
                                    />
                                </MultiComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                        <fb:FilterGroupItem
                            name="CategoryID"
                            label="Category"
                            groupName="Group1"
                            visibleInFilterBar="true"
                        >
                            <fb:control>
                                <MultiComboBox
                                    name="CategoryID"
                                    selectionChange=".onSelectionChange"
                                    items="{
												path: '/Categories',
												templateShareable: false
											}"
                                >
                                    <core:Item
                                        key="{CategoryID}"
                                        text="{CategoryID}"
                                    />
                                </MultiComboBox>
                            </fb:control>
                        </fb:FilterGroupItem>
                    </fb:filterGroupItems>
                </fb:FilterBar>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <Table
                id="idTable"
                items="{/Products}"
                itemPress="onItemSelect"
                class="sapUiTinyMargin myCustomTable"
                alternateRowColors="true"
                sticky="ColumnHeaders,HeaderToolbar"
            >
                <headerToolbar>
                    <Toolbar>
                        <HBox
                            justifyContent="Center"
                            width="100%"
                        >
                            <SearchField
                                id="idSearch"
                                placeholder="{i18n>SEARCH_PLCHD}"
                                liveChange="onSearch"
                                width="100%"
                            />
                        </HBox>
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column>
                        <Text text="{i18n>PRODUCTID_TXT}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>PROD_NAME_TXT}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>SUPP_ID_TXT}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>CATE_ID_TXT}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>QUANT_UNIT_TXT}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>PRICE_TXT}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>UNIT_STOCK_TXT}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>UNIT_ORDER_TXT}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>RECORD_TXT}" />
                    </Column>
                    <Column>
                        <Text text="{i18n>DISCONT_TXT}" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation">
                        <cells>
                            <Text text="{ProductID}" />
                            <Text text="{ProductName}" />
                            <Text text="{SupplierID}" />
                            <Text text="{CategoryID}" />
                            <Text text="{QuantityPerUnit}" />
                            <Text text="{UnitPrice}" />
                            <Text text="{UnitsInStock}" />
                            <Text text="{UnitsOnOrder}" />
                            <Text text="{ReorderLevel}" />

                            <!-- ✅ Colored Status -->
                            <ObjectStatus
                                text="{path: 'Discontinued', formatter: '.formatter.getStatusText'}"
                                state="{path: 'Discontinued', formatter: '.formatter.getStatusState'}"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
        <f:footer>
            <OverflowToolbar>
                <Text
                    id="priceTotal"
                    text="Price: 0"
                />
                <ToolbarSpacer />
                <Text
                    id="stockTotal"
                    text="In Stock: 0"
                />
                <ToolbarSpacer />
                <Text
                    id="orderTotal"
                    text="On Order: 0"
                />
            </OverflowToolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>
