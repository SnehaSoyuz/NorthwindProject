<mvc:View
    xmlns:f="sap.f"
    controllerName="com.excnorthwindproject.excnorthwindproject.controller.View2"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
>
    <Page
     class= "myCustomPage2"
     title="Supplier Data">
        <form:SimpleForm>
            <form:content>
                <Label text="Company Name" />
                <Text
                    text="{CompanyName}"
                    id="idTextCompanyName"
                />
                <Label text="Contact Name" />
                <Text text="{ContactName}" />
                <Label text="Country"/>
                <Text text="{Country}"/>
                <Label text="City" />
                <Text text="{City}" />
            </form:content>
        </form:SimpleForm>
    </Page>
</mvc:View>
